{
  "name": "create-multistack",
  "version": "0.1.1",
  "description": "CLI interactif pour scaffolder des projets multi-frameworks (React, Next.js, Vue, Angular, Svelte, Astro) avec TypeScript, Tailwind, ESLint, Prettier, Vitest et plus.",
  "type": "module",
  "bin": {
    "create-multistack": "./bin/index.js"
  },
  "main": "./bin/index.js",
  "scripts": {
    "start": "node bin/index.js",
    "dev": "node bin/index.js",
    "validate": "node scripts/validate.js",
    "prepublishOnly": "node scripts/validate.js"
  },
  "files": [
    "bin/",
    "src/",
    "shared/",
    "scripts/validate.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "keywords": [
    "cli",
    "scaffolding",
    "boilerplate",
    "create-app",
    "react",
    "nextjs",
    "vue",
    "angular",
    "svelte",
    "astro",
    "typescript",
    "tailwind",
    "vite"
  ],
  "author": "bibalaye",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bibalaye/create-multistack.git"
  },
  "homepage": "https://github.com/bibalaye/create-multistack#readme",
  "bugs": {
    "url": "https://github.com/bibalaye/create-multistack/issues"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "execa": "^9.6.1",
    "fs-extra": "^11.3.4",
    "picocolors": "^1.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
